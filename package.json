{
  "name": "@zanwaar/tiptap-docs-kit",
  "version": "0.1.0",
  "type": "module",
  "description": "Tiptap kit for document editors with Word-like pages, pagination, and document styling.",
  "keywords": [
    "tiptap",
    "prosemirror",
    "editor",
    "wysiwyg",
    "document",
    "pagination",
    "word",
    "a4"
  ],
  "license": "MIT",
  "author": "zanwaar",
  "homepage": "https://github.com/zanwaar/tiptap-docs-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zanwaar/tiptap-docs-kit.git"
  },
  "bugs": {
    "url": "https://github.com/zanwaar/tiptap-docs-kit/issues"
  },
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "preview.png"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/style.css dist/style.css",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-table": "^3.26.1",
    "@tiptap/extension-table-cell": "^3.26.1",
    "@tiptap/extension-table-header": "^3.26.1",
    "@tiptap/extension-table-row": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1"
  },
  "devDependencies": {
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-table": "^3.26.1",
    "@tiptap/extension-table-cell": "^3.26.1",
    "@tiptap/extension-table-header": "^3.26.1",
    "@tiptap/extension-table-row": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "typescript": "~6.0.2"
  }
}
